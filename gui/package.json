{
  "name": "@moduleforge/users-gui",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && bun run build:css",
    "build:css": "bunx @tailwindcss/cli -i src/styles.css -o dist/index.css --minify",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist build .yalc yalc.lock",
    "dev": "ladle serve --port 61002",
    "preview:build": "ladle build"
  },
  "dependencies": {
    "@moduleforge/core-gui": "file:.yalc/@moduleforge/core-gui",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "@moduleforge/core-gui": "*",
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "@moduleforge/core-gui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ladle/react": "^5",
    "@tailwindcss/vite": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4",
    "tsup": "^8",
    "typescript": "^5",
    "vite": "^5"
  }
}
