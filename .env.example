# =============================================================================
# users-module local dev environment
# =============================================================================
# Copy to .env and edit. The defaults below are safe for local development;
# override for any non-local deployment.
#
# docker-compose.yml, the API server, and the GUI all read from this file.
# =============================================================================

# ---- Deployment mode --------------------------------------------------------
DEPLOY_MODE=local

# ---- Postgres ---------------------------------------------------------------
POSTGRES_USER=users
POSTGRES_PASSWORD=users
POSTGRES_DB=users
POSTGRES_PORT=5432
# API reads DB_URL directly:
DB_URL=postgresql://users:users@localhost:5432/users?sslmode=disable

# ---- API server -------------------------------------------------------------
SERVER_ADDR=:8080
GUI_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ---- Authelia / OIDC --------------------------------------------------------
# NOTE: for local dev you must add `127.0.0.1  authelia` to /etc/hosts so the
# browser can reach Authelia at the same hostname the API uses. See
# deploy/local/README.md (First-time setup) for the full explanation.
AUTHELIA_PORT=9091

# Secrets must be >= 32 chars. Change these for anything beyond local dev.
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=change-me-jwt-secret-at-least-32-chars-long
AUTHELIA_SESSION_SECRET=change-me-session-secret-at-least-32-chars
AUTHELIA_STORAGE_ENCRYPTION_KEY=change-me-storage-encryption-key-at-least-32
AUTHELIA_IDENTITY_PROVIDERS_OIDC_HMAC_SECRET=change-me-oidc-hmac-secret-at-least-32

# --- Auth providers ---
# Enable providers by setting their CLIENT_ID/CLIENT_SECRET below.
# Local dev uses Authelia (automatic via docker-compose; the AUTH_PROVIDER_AUTHELIA_*
# values are baked into deploy/local/docker-compose.yml so you don't need to
# set them here unless you want to override the default client secret).
#
# To enable Google in local dev, create a Google Cloud OAuth 2.0 Client
# (https://console.cloud.google.com/apis/credentials) with:
#   - Application type: Web application
#   - Authorized redirect URI: http://localhost:8080/v1/auth/oidc/google/callback
# Then set:
#
# AUTH_PROVIDER_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# AUTH_PROVIDER_GOOGLE_CLIENT_SECRET=...
#
# Microsoft: you need to "register an app" with Entra ID and then ctreate a
# secret key. The '..._CLIENT_ID' is the app ID and the '..._CLIENT_SECRET' is
# the secret key value. For the "supported account types" allowed to log in or
# create an account, 'Single tenant - Default Directory' means only users pre-
# registered through Entra Entra ID (or AD?) can use the app. If you want
# anyone with an MS account to access the app, use 'Any Entra ID Tenant +
# Personal Microsoft Accounts'.
#
# Set the callback URL: http://localhost:8080/v1/auth/oidc/microsoft/callback
#
# The '...ISSUER_URL' depends on what you choose; for a single tenant, it will
# be:
# https://login.microsoftonline.com/{ client ID }/v2.0
# For multi-tenant:
# https://login.microsoftonline.com/common/v2.0 (which is the default)
#
# For any non-well-known provider (e.g. self-hosted Keycloak), all fields
# must be set explicitly:
#   AUTH_PROVIDER_<ID>_DISPLAY_NAME=...
#   AUTH_PROVIDER_<ID>_ISSUER_URL=...
#   AUTH_PROVIDER_<ID>_CLIENT_ID=...
#   AUTH_PROVIDER_<ID>_CLIENT_SECRET=...
#   AUTH_PROVIDER_<ID>_CLAIM_STYLE=<google|microsoft|authelia|generic|...>
#   AUTH_PROVIDER_<ID>_SCOPES=openid,email,profile   # optional
#
# AUTH_PROVIDERS may be set to a comma-separated allowlist of provider IDs;
# if unset, providers are auto-discovered from any AUTH_PROVIDER_<ID>_CLIENT_ID
# that is non-empty.

# Override the local Authelia client secret (must match the hash committed in
# deploy/local/authelia/configuration.yml). Defaults to "local-authelia-secret".
# AUTH_PROVIDER_AUTHELIA_CLIENT_SECRET=local-authelia-secret

# URLs used by the OAuth flow (only needed if any provider is enabled).
AUTH_OAUTH_REDIRECT_BASE_URL=http://localhost:8080
AUTH_FRONTEND_RETURN_URL=http://localhost:3000/auth/oidc/return

# Post-normalization role string that grants admin scope (default: "admin").
AUTH_ADMIN_ROLE=admin

# ---- Local auth (non-OIDC) --------------------------------------------------
JWT_SECRET=change-me-jwt-secret-for-local-auth-at-least-32-chars
LOCAL_ISSUER=users-module-local

# ---- Mailpit / SMTP ---------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@example.test
MAILPIT_UI_PORT=8025

# ---- pgAdmin (Postgres web UI, local dev only) ------------------------------
# The pgAdmin container auto-registers the Postgres server via
# deploy/local/pgadmin/servers.json — open the UI, click the "users-module
# (local)" server, type the Postgres password ("users") once. Credentials
# below are for the pgAdmin login itself, not the database.
PGADMIN_DEFAULT_EMAIL=admin@example.test
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_UI_PORT=5050

# ---- Timezone (used by Authelia container) -----------------------------------
TZ=UTC
